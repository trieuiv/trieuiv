mixed-port: 7890
allow-lan: true
bind-address: '*'
mode: rule
log-level: info
ipv6: true
external-controller: '127.0.0.1:9090'
dns:
  enable: true
  ipv6: true
  use-hosts: true
  enhanced-mode: redir-host
  default-nameserver:
    - 1.1.1.1
    - 8.8.8.8
  nameserver:
    - 'https://cloudflare-dns.com/dns-query'
    - 'https://dns.google/dns-query'
    - 'https://dns.quad9.net/dns-query'
  fallback:
    - 'tls://1.0.0.1:853'
    - 'tls://8.8.4.4:853'
  fallback-filter:
    geoip: true
    ipcidr:
      - 240.0.0.0/4
      - 0.0.0.0/32
proxies:
  -
    name: '🇻🇳Youtube Premium Public HCM'
    type: ss
    server: hcm.fzpn.net
    port: 117
    cipher: 2022-blake3-aes-256-gcm
    password: 'YghWY4stNd9HIQlolHMpxk90iXGtNKVuELK5Tn1F2kk=:YzdhNDU3ZTUtY2YyZi01MzUwLTg5MTktYjcyNTU0N2Y='
    udp: true
  -
    name: '🇻🇳Youtube Premium Public HN'
    type: ss
    server: hn.fzpn.net
    port: 116
    cipher: 2022-blake3-aes-256-gcm
    password: 'YghWY4stNd9HIQlolHMpxk90iXGtNKVuELK5Tn1F2kk=:YzdhNDU3ZTUtY2YyZi01MzUwLTg5MTktYjcyNTU0N2Y='
    udp: true
proxy-groups:
  -
    name: Proxy
    type: select
    proxies:
      - Auto
      - 'Fault transfer'
      - '🇻🇳Youtube Premium Public HCM'
      - '🇻🇳Youtube Premium Public HN'
  -
    name: Auto
    type: url-test
    proxies:
      - '🇻🇳Youtube Premium Public HCM'
      - '🇻🇳Youtube Premium Public HN'
    url: 'http://www.gstatic.com/generate_204'
    interval: 86400
  -
    name: 'Fault transfer'
    type: fallback
    proxies:
      - '🇻🇳Youtube Premium Public HCM'
      - '🇻🇳Youtube Premium Public HN'
    url: 'http://www.gstatic.com/generate_204'
    interval: 7200
  -
    name: VN
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      - '🇻🇳Youtube Premium Public HCM'
      - '🇻🇳Youtube Premium Public HN'
rules:
  # 1. Panel quản lý - kết nối trực tiếp
  - 'DOMAIN,panel.fuzzypn.me,DIRECT'

  # 2. Chặn quảng cáo tổng quát (GeoSite)
  - 'GEOSITE,category-ads-all,REJECT'

  # 3. Chặn các domain quảng cáo Google/YouTube cụ thể
  - 'DOMAIN-SUFFIX,doubleclick.net,REJECT'
  - 'DOMAIN-SUFFIX,googlesyndication.com,REJECT'
  - 'DOMAIN-SUFFIX,googleadservices.com,REJECT'
  - 'DOMAIN-SUFFIX,google-analytics.com,REJECT'
  - 'DOMAIN-SUFFIX,googletagmanager.com,REJECT'
  - 'DOMAIN-SUFFIX,googletagservices.com,REJECT'
  - 'DOMAIN-SUFFIX,googleapis.com/log,REJECT'
  - 'DOMAIN,pagead2.googlesyndication.com,REJECT'
  - 'DOMAIN,ads.youtube.com,REJECT'
  - 'DOMAIN,ad.youtube.com,REJECT'
  - 'DOMAIN-SUFFIX,app-measurement.com,REJECT'
  - 'DOMAIN-SUFFIX,crashlytics.com,REJECT'

  # 4. Chặn tracking/telemetry YouTube
  - 'DOMAIN,play.google.com/log,REJECT'
  - 'DOMAIN-KEYWORD,/pagead/,REJECT'
  - 'DOMAIN-KEYWORD,/ptracking,REJECT'
  - 'DOMAIN-KEYWORD,/api/stats/,REJECT'

  # 5. Chặn QUIC/UDP để force TCP (tăng hiệu quả chặn ads)
  - 'AND,((DOMAIN-SUFFIX,googlevideo.com),(NETWORK,udp)),REJECT'
  - 'AND,((DOMAIN,youtubei.googleapis.com),(NETWORK,udp)),REJECT'

  # 6. Route YouTube qua Proxy (để hưởng YouTube Premium VN)
  - 'DOMAIN-SUFFIX,youtube.com,Proxy'
  - 'DOMAIN-SUFFIX,youtu.be,Proxy'
  - 'DOMAIN-SUFFIX,ytimg.com,Proxy'
  - 'DOMAIN-SUFFIX,googlevideo.com,Proxy'          # ← Video stream, PHẢI qua Proxy
  - 'DOMAIN,youtubei.googleapis.com,Proxy'          # ← YouTube API, PHẢI qua Proxy
  - 'DOMAIN-SUFFIX,youtube-nocookie.com,Proxy'
  - 'DOMAIN-SUFFIX,yt3.ggpht.com,Proxy'
  - 'DOMAIN-SUFFIX,yt3.googleusercontent.com,Proxy'
  - 'DOMAIN-KEYWORD,youtube,Proxy'

  # 7. Chặn thêm domain quảng cáo Google
  - 'DOMAIN-SUFFIX,adsense.google.com,REJECT'
  - 'DOMAIN-SUFFIX,adservice.google.com,REJECT'

  # 8. Mọi traffic khác - kết nối trực tiếp
  - 'MATCH,DIRECT'
